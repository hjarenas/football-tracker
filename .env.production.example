# Production Environment Variables
# Copy this file to .env on the Hetzner VPS and fill in all values.
# Never commit the actual .env file — it contains secrets.

# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string used by the Next.js app (via Prisma).
# The host must match the docker-compose service name (db) when running in
# Docker Compose on the same network.
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/dienstagskicken

# Postgres container credentials — must match DATABASE_URL above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=dienstagskicken

# ─── NextAuth.js ──────────────────────────────────────────────────────────────
# Random secret used to sign JWT session tokens.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME

# Public URL of the deployed app (must use https in production).
NEXTAUTH_URL=https://yourdomain.com

# ─── Admin credentials ────────────────────────────────────────────────────────
# Comma-separated list of username:password pairs for the admin interface.
# Example: ADMIN_CREDENTIALS=admin:sicherespasswort,backup:anderes-passwort
ADMIN_CREDENTIALS=admin:CHANGE_ME

# ─── Caddy / TLS ──────────────────────────────────────────────────────────────
# The public domain name Caddy will serve and obtain a Let's Encrypt cert for.
# Must match NEXTAUTH_URL (without the https:// scheme).
DOMAIN=yourdomain.com

# ─── GitHub Actions secrets (set in repository settings, not in this file) ───
# DEPLOY_HOST  — IP address or hostname of the Hetzner VPS
# HETZNER_SSH_KEY — Private SSH key whose public key is in ~/.ssh/authorized_keys
#                   on the VPS deploy user

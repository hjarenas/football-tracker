# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dienstagskicken

# NextAuth.js
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Admin credentials (comma-separated username:password pairs)
# Example: ADMIN_CREDENTIALS=admin:sicherespasswort,backup:anderes-passwort
ADMIN_CREDENTIALS=admin:password

// Dienstagskicken — Prisma Schema
// Score is NEVER stored — always derived from Tor records (ADR-0002)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Team enum — only ever Rot or Gelb (from the paper sheet)
enum Team {
  Rot
  Gelb
}

// Match status state machine: geplant → teams_zugewiesen → abgeschlossen | abgesagt
enum SpielStatus {
  geplant
  teams_zugewiesen
  abgeschlossen
  abgesagt
}

// Spieler — a football player
model Spieler {
  id        String   @id @default(cuid())
  name      String   @unique
  aktiv     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  teilnahmen    Spielteilnahme[] @relation("SpielerTeilnahmen")
  toreGescossen Tor[]            @relation("TorScorer")
  vorlagen      Tor[]            @relation("TorAssist")
  bierSpiele    Spiel[]          @relation("Bierbringer")
}

// Saison — calendar year
model Saison {
  id   String @id @default(cuid())
  jahr Int    @unique // Calendar year, e.g. 2026

  // Relations
  spiele Spiel[]
}

// Spiel — a football match
model Spiel {
  id        String      @id @default(cuid())
  datum     DateTime    @db.Date
  status    SpielStatus @default(geplant)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Foreign keys
  saisonId      String
  bierbringerId String?

  // Relations
  saison      Saison           @relation(fields: [saisonId], references: [id], onDelete: Restrict)
  bierbringer Spieler?         @relation("Bierbringer", fields: [bierbringerId], references: [id], onDelete: SetNull)
  teilnahmen  Spielteilnahme[]
  tore        Tor[]
}

// Spielteilnahme — match participation (join: Spieler × Spiel)
// team is null at Step 1 (geplant); assigned in Step 2 (teams_zugewiesen)
model Spielteilnahme {
  id             String  @id @default(cuid())
  team           Team?   // Null until teams are assigned (Step 2)
  punkteOverride Team?   // Override: which team gets the points (null = use match result)

  // Foreign keys
  spielerId String
  spielId   String

  // Relations
  spieler Spieler @relation("SpielerTeilnahmen", fields: [spielerId], references: [id], onDelete: Cascade)
  spiel   Spiel   @relation(fields: [spielId], references: [id], onDelete: Cascade)

  @@unique([spielerId, spielId]) // A player can only participate once per match
}

// Tor — a goal event
// Eigentore: counted toward opposing team's score, NOT scorer's personal tally
model Tor {
  id       String  @id @default(cuid())
  team     Team    // Which team scored (for scoring: if eigentor, this is the SHOOTING team, goal counts for OPPONENT)
  eigentor Boolean @default(false)

  // Foreign keys
  spielId   String
  scorerId  String
  assistId  String?

  // Relations
  spiel   Spiel    @relation(fields: [spielId], references: [id], onDelete: Cascade)
  scorer  Spieler  @relation("TorScorer", fields: [scorerId], references: [id], onDelete: Restrict)
  assist  Spieler? @relation("TorAssist", fields: [assistId], references: [id], onDelete: SetNull)
}
